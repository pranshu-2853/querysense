# ============================================================
# QuerySense — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================

# --- Application Database (PostgreSQL with pgvector) ---
APP_DB_PASSWORD=querysense_secret

# --- Analytics Database ---
ANALYTICS_SUPERUSER_PASSWORD=analytics_super_secret
ANALYTICS_READONLY_PASSWORD=readonly_password
ANALYTICS_INTROSPECT_PASSWORD=introspect_password

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Groq API (LLM for SQL generation and explanation) ---
GROQ_API_KEY=gsk_your_groq_api_key_here

# --- AI Models ---
MODEL_SQL=llama-3.3-70b-versatile
MODEL_EXPLANATION=llama-3.3-70b-versatile
EMBEDDING_MODEL=nomic-embed-text

# --- Ollama (local embeddings) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- JWT (used in Phase 03+) ---
JWT_SECRET=your-256-bit-secret-key-for-jwt-signing-minimum-32-chars
